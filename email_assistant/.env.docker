# Docker Compose environment — copy to .env.docker and fill in real values.
# The DATABASE_URL and Neo4j vars are set directly in docker-compose.yml
# so you only need to provide secrets and integration credentials here.

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_ATTACHMENT_SUMMARY_MODEL=gpt-4o-mini
OPENAI_STYLE_PROFILE_MODEL=gpt-4o-mini

# Microsoft Azure / Outlook
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Feature flags
USE_DECAYED_WEIGHT=true
USE_PREFERENCE_VECTOR=true

# App mode
APP_ROLE=api
AUTO_CREATE_SCHEMA=false
ENABLE_BACKGROUND_WORKERS=false
FRONTEND_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Timezone
DEFAULT_USER_TIMEZONE=Asia/Singapore
