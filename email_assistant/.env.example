# OUMA schema
OUMA_SCHEMA_VERSION=ouma.v2
DEFAULT_USER_TIMEZONE=Asia/Singapore

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ouma
SQL_ECHO=false

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Microsoft Azure / Outlook
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# Agent settings
MAX_ATTACHMENT_TEXT_LENGTH=200000
MAX_CLASSIFIER_CONTEXT_CHARS=12000
MAX_RESPONSE_CONTEXT_CHARS=6000
